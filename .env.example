# =====================================================================
# DNAbeat.pro — SERVER-SIDE secrets (set these in Vercel → Settings → Environment Variables)
# NEVER expose these in the browser. They are only read inside /api/* functions.
# =====================================================================

# --- Gemini (Google AI Studio) ---
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- OpenAI Whisper (Tab 4 Timing Lyrics — speech-to-text w/ timestamps) ---
# Get a key: https://platform.openai.com/api-keys
# Optional: if omitted, Tab 4 still works using Gemini-only (less precise timing).
OPENAI_API_KEY=your_openai_api_key_here

# --- Supabase (service role = full DB access, server-only) ---
# Dashboard → Project Settings → API → service_role secret
SUPABASE_URL=https://ynyfvszgxhmldjnlcmcy.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# --- PayPal (for verifying webhooks / marking users premium) ---
# Dashboard → Apps & Credentials. Use LIVE creds for production.
PAYPAL_CLIENT_ID=AWi9P8SawyFUKD_g8vjK6jfjxiOnjMzYj7qwiDQsCQldRiZOC7ieKkAA_LWNRD8HMisVRJ1vc_n6Jxq-
PAYPAL_CLIENT_SECRET=your_paypal_client_secret_here
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id_here
# 'live' or 'sandbox'
PAYPAL_ENV=live

# --- Free tier limit (per UTC day) ---
FREE_DAILY_LIMIT=5
