{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "api/analyze.js": { "maxDuration": 60 },
    "api/timing.js": { "maxDuration": 60 },
    "api/youtube.js": { "maxDuration": 60 },
    "api/usage.js": { "maxDuration": 10 },
    "api/paypal-webhook.js": { "maxDuration": 15 }
  },
  "rewrites": [
    { "source": "/app", "destination": "/app.html" },
    { "source": "/youtube", "destination": "/youtube.html" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
